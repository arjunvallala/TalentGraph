# ═══════════════════════════════════════════════════════════════════════════════
# TalentGraph AI — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=TalentGraph AI
APP_VERSION=0.1.0
APP_ENV=development
# development | production | test
DEBUG=true
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true
# CORS origins (comma-separated, or * for all)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# When true, loads pre-generated demo data instead of running the pipeline.
# Essential for hackathon demos where pipeline runtime is not acceptable.
DEMO_MODE=false
DEMO_DATA_PATH=data/demo

# ── Data Paths ────────────────────────────────────────────────────────────────
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_INDEXES_PATH=data/indexes

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=data/processed/talentgraph.duckdb

# ── FAISS ─────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/indexes/candidates.faiss
FAISS_METADATA_PATH=data/indexes/faiss_metadata.pkl

# ── BM25 ──────────────────────────────────────────────────────────────────────
BM25_INDEX_PATH=data/indexes/bm25_index.pkl

# ── Embedding Model ───────────────────────────────────────────────────────────
# Model will be downloaded to this path on first run
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_MODEL_PATH=models/embeddings/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DIMENSION=384

# ── Preprocessing ─────────────────────────────────────────────────────────────
PREPROCESSING_CHECKPOINT_PATH=data/processed/.checkpoints
PREPROCESSING_BATCH_SIZE=1000
PREPROCESSING_MAX_WORKERS=4

# ── Ranking ───────────────────────────────────────────────────────────────────
RANKING_STAGE1_TOP_K=2000
RANKING_STAGE2_TOP_K=200
RANKING_STAGE3_TOP_K=100
RANKING_FINAL_TOP_K=100

# ── Retrieval ─────────────────────────────────────────────────────────────────
SEMANTIC_TOP_K=1500
BM25_TOP_K=1500
HYBRID_ALPHA=0.6
# alpha=1.0 = pure semantic, alpha=0.0 = pure BM25

# ── Confidence ────────────────────────────────────────────────────────────────
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_LOW_THRESHOLD=0.45

# ── Submission ────────────────────────────────────────────────────────────────
SUBMISSION_OUTPUT_PATH=data/submission.csv

# ── Configs ───────────────────────────────────────────────────────────────────
CONFIG_PATH=configs

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE_PATH=logs/talentgraph.log
LOG_ROTATION=500 MB
LOG_RETENTION=10 days
